<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:h="http://xmlns.jcp.org/jsf/html"
      xmlns:p="http://primefaces.org/ui">
	<h:head>
	    <title>Reports List</title>
	    <link rel="stylesheet"
	          href="https://unpkg.com/primeflex@latest/primeflex.css" />
	</h:head>
	<h:body>
	    <h2>New Report</h2>
	    <h:form>
	        <div class="ui-fluid">
	            <div class="field">
	                <h:">
	            <div class="field">
	                <h:outputLabel for="title-input" value="Title" />
	                <p:inputText id="title-input"
	                             value="#{reportNewBean.title}" />
	                <h:message for="title-input" style="color: red" />
	            </div>
	            <div class="field">
	                <h:outputLabel for="detail-input" value="Detail" />
	                <p:inputTextarea id="detail-input"
	                                 value="#{reportNewBean.detail}"
	                                 rows="6" />
	                <h:message for="detail-input" style="color: red" />
	            </div>
	        </div>
	        <div class="flex justify-content-end">
	            <p:commandButton value="Create"
	                             ajax="false"
	                             action="#{reportNewBean.create()}" />
	        </div>
	    </h:form>
	    <div>
	        <h:outputText value="#{reportNewBean.title}" />
	    </div>
	    <div>
	        <h:outputText value="#{reportNewBean.detail}"
	                      style="white-space: pre-wrap;" />
	    </div>
	</h:body>
</html>